; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Board Game Girl"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/art/icon.svg"

[autoload]

GameState="*res://scripts/autoloads/game_state.gd"
ReactionManager="*res://scripts/child/reaction_manager.gd"
HintManager="*res://scripts/child/hint_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
SaveSystem="*res://scripts/autoloads/save_system.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
