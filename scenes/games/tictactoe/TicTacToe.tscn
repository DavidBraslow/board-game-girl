[gd_scene load_steps=2 format=3 uid="uid://b3k7xymtictac"]

[ext_resource type="Script" path="res://scripts/game_logic/tictactoe/tictactoe.gd" id="1_q7d4p"]

; Root node fills the full viewport. Script attached here.
[node name="TicTacToeGame" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_q7d4p")

; GridContainer arranges the 9 cell Buttons into a 3-column grid.
; Anchored to the centre of its parent so the board sits in the middle of the screen.
[node name="GameBoard" type="GridContainer" parent="."]
layout_mode = 1
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -150.0
offset_right = 150.0
offset_bottom = 150.0
grow_horizontal = 2
grow_vertical = 2
columns = 3

[node name="Cell0" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell1" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell2" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell3" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell4" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell5" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell6" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell7" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

[node name="Cell8" type="Button" parent="GameBoard"]
custom_minimum_size = Vector2(100, 100)

; Each cell button passes its own index to _on_cell_pressed via the binds array.
[connection signal="pressed" from="GameBoard/Cell0" to="." method="_on_cell_pressed" binds=[0]]
[connection signal="pressed" from="GameBoard/Cell1" to="." method="_on_cell_pressed" binds=[1]]
[connection signal="pressed" from="GameBoard/Cell2" to="." method="_on_cell_pressed" binds=[2]]
[connection signal="pressed" from="GameBoard/Cell3" to="." method="_on_cell_pressed" binds=[3]]
[connection signal="pressed" from="GameBoard/Cell4" to="." method="_on_cell_pressed" binds=[4]]
[connection signal="pressed" from="GameBoard/Cell5" to="." method="_on_cell_pressed" binds=[5]]
[connection signal="pressed" from="GameBoard/Cell6" to="." method="_on_cell_pressed" binds=[6]]
[connection signal="pressed" from="GameBoard/Cell7" to="." method="_on_cell_pressed" binds=[7]]
[connection signal="pressed" from="GameBoard/Cell8" to="." method="_on_cell_pressed" binds=[8]]
