[gd_scene load_steps=2 format=3 uid="uid://bchildcharact"]

[ext_resource type="Script" path="res://scripts/child/child_character.gd" id="1_child"]

; Root fills the viewport so the child character can be positioned anywhere.
[node name="ChildCharacter" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_child")

; Character sprite — texture set at runtime from assets/art/girl.png when available.
[node name="CharacterSprite" type="TextureRect" parent="."]
layout_mode = 1
anchor_left = 1.0
anchor_top = 0.5
anchor_right = 1.0
anchor_bottom = 0.5
offset_left = -180.0
offset_top = -150.0
offset_right = -20.0
offset_bottom = 150.0
grow_horizontal = 0
expand_mode = 3

; AnimationPlayer — add animations here when art is ready.
; The script looks for: idle, react_wrong, react_warm, react_correct,
; react_celebrate, react_hint. Falls back to idle silently if not found.
[node name="AnimationPlayer" type="AnimationPlayer" parent="."]

; DialogueLabel — anchored to the bottom centre of the screen.
; Style this however you like; the script sets .text directly.
[node name="DialogueLabel" type="Label" parent="."]
layout_mode = 1
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -80.0
grow_vertical = 0
horizontal_alignment = 1

; Accept/Decline buttons — shown only when the tier-3 guidance offer fires.
[node name="GuidanceOfferPanel" type="HBoxContainer" parent="."]
visible = false
layout_mode = 1
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -100.0
offset_top = -40.0
offset_right = 100.0
grow_vertical = 0

[node name="AcceptButton" type="Button" parent="GuidanceOfferPanel"]
text = "Accept"

[node name="DeclineButton" type="Button" parent="GuidanceOfferPanel"]
text = "Decline"

[connection signal="pressed" from="GuidanceOfferPanel/AcceptButton" to="." method="_on_accept_pressed"]
[connection signal="pressed" from="GuidanceOfferPanel/DeclineButton" to="." method="_on_decline_pressed"]
