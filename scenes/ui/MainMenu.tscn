grow_vertical = 2

[node name="TitleLabel" type="Label" parent="VBoxContainer"]
text = "Board Game Girl"

[node name="GamesContainer" type="VBoxContainer" parent="VBoxContainer"]

[node name="TicTacToeButton" type="Button" parent="VBoxContainer/GamesContainer"]
